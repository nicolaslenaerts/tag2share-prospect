# Copie ce fichier en .env.local et remplis les valeurs.

# Mot de passe d'accès à l'app (auth partagée). Sans lui, l'app reste verrouillée
# (login impossible) hormis /api/unsubscribe et /api/webhooks/resend.
APP_PASSWORD=

NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

GOOGLE_MAPS_API_KEY=
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

ANTHROPIC_API_KEY=
MISTRAL_API_KEY=

RESEND_API_KEY=
RESEND_FROM=Nicolas de Tag2Share <nicolas@marketing.tag2share.com>
# Adresse de réponse par défaut (les réponses arrivent ici, pas sur le domaine d'envoi).
RESEND_REPLY_TO=nicolas@tag2share.com
# Secret de signature du webhook Resend (whsec_...), pour bounces/plaintes -> suppression.
RESEND_WEBHOOK_SECRET=

TEST_EMAIL=you@example.com

# URL publique de l'app (liens de désinscription absolus dans les emails).
APP_URL=https://marketing.tag2share.com
# Secret pour signer les liens de désinscription (sinon SUPABASE_SERVICE_ROLE_KEY).
UNSUBSCRIBE_SECRET=

# Identité expéditeur affichée dans le footer (RGPD : être identifiable + contact).
SENDER_NAME=Tag2Share
# Adresse postale OPTIONNELLE (non requise en B2B RGPD) : laisser vide pour ne pas l'afficher.
SENDER_ADDRESS=
SENDER_CONTACT=tag2share.com

# Délivrabilité : plafond d'envois par jour (0 = illimité) et délai entre envois (ms).
# 50 = marge sous la limite Resend gratuit (100/jour). Passer à 0 avec Resend Pro.
DAILY_SEND_CAP=50
SEND_DELAY_MS=1200
